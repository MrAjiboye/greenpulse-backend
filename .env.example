# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=GreenPulse API
DEBUG=False

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (local dev)
DATABASE_URL=sqlite:///./greenpulse.db

# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql://greenpulse:yourpassword@localhost:5432/greenpulse
# POSTGRES_PASSWORD=greenpulse_secret

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-key

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend ───────────────────────────────────────────────────────────────────
# Used to build links in emails (verify email, password reset)
FRONTEND_URL=https://yourdomain.com

# ── Email — Resend (resend.com) ────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=no-reply@support.greenpulseanalytics.com
FROM_NAME=GreenPulse

# ── OAuth — Google ─────────────────────────────────────────────────────────────
# Get credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/google/callback

# ── OAuth — Microsoft ──────────────────────────────────────────────────────────
# Get credentials at https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/microsoft/callback

# ── AI / LLM (optional — not currently used by the ML engine) ─────────────────
# If you integrate an LLM for insight generation, add your key here
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── ML Engine ──────────────────────────────────────────────────────────────────
ML_AUTO_RETRAIN=True
ML_RETRAIN_EVERY_N_READINGS=100

# ── Google Cloud ML (optional — Vertex AI / BigQuery ML) ──────────────────────
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_REGION=europe-west2
# GOOGLE_CLOUD_CREDENTIALS_JSON=
# VERTEX_AI_ENDPOINT_ID=
# BIGQUERY_DATASET=

# ── AWS SageMaker (optional) ───────────────────────────────────────────────────
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SAGEMAKER_ENDPOINT_NAME=
