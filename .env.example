# App
APP_NAME=GreenPulse API
DEBUG=false

# Database — SQLite (local dev, no Docker)
DATABASE_URL=sqlite:///./greenpulse.db

# Database — PostgreSQL (Docker / production)
# DATABASE_URL=postgresql://greenpulse:yourpassword@localhost:5432/greenpulse

# PostgreSQL password used by docker-compose
# POSTGRES_PASSWORD=greenpulse_secret

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-key

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI
OPENAI_API_KEY=
